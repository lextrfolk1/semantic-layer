<configuration>
    <springProperty scope="context" name="APP_LOG_LEVEL" source="logging.level.com.lextr.semanticlayer" defaultValue="INFO"/>

    <property name="CONSOLE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - [semantic-layer] %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <logger name="com.lextr.semanticlayer" level="${APP_LOG_LEVEL}"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
